{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  },
  "globalDependencies": [
    ".env"
  ],
  "globalEnv": [
    "FRONTEND_SMTP_HOST",
    "FRONTEND_SMTP_PORT",
    "FRONTEND_SMTP_USER",
    "FRONTEND_SMTP_PASS",
    "FRONTEND_GROQ_API_KEY",
    "FRONTEND_NEXT_PUBLIC_API_URL",
    "BACKEND_PORT",
    "BACKEND_MONGO_URI",
    "BACKEND_JWT_SECRET",
    "BACKEND_EMAIL_USER",
    "BACKEND_EMAIL_PASS"
  ]
}